# ───────────────────────────────────────────────────────────────────────────
# Crystal Core — environment configuration
# Copy this file to .env.local and fill in real values.
# ───────────────────────────────────────────────────────────────────────────

# 32+ random bytes. Generate with:  openssl rand -base64 48
JWT_SECRET=replace-with-strong-random-secret-min-32-chars

# How long an issued JWT stays valid (jose duration string).
JWT_EXPIRY=8h

# Apps Script Web App URL (deployed as "anyone, even anonymous").
# Looks like: https://script.google.com/macros/s/AKfycb.../exec
APPS_SCRIPT_URL=https://script.google.com/macros/s/REPLACE_ME/exec

# Shared secret sent in every request to the Apps Script web app.
# Apps Script verifies this against its own SCRIPT_SHARED_SECRET property.
APPS_SCRIPT_SHARED_SECRET=replace-with-shared-secret

# Bcrypt cost factor (10–12 in production).
BCRYPT_COST=12

# Optional: comma-separated emails that are auto-approved as developers
# the very first time they sign up (bootstrap). Leave blank in prod.
BOOTSTRAP_DEVELOPER_EMAILS=

# ───────────────────────────────────────────────────────────────────────────
# Where each downstream system is hosted.  Used by the dashboard to render
# clickable launcher tiles. Leave blank to grey the tile out.
#
# Local dev:  http://localhost:3001
# Prod:       https://wms.crystalgroup.in
# ───────────────────────────────────────────────────────────────────────────
SYSTEM_URL_PROCUREMENT=
SYSTEM_URL_WMS=
SYSTEM_URL_HIRING=
SYSTEM_URL_REPORTS=
